# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=uphunter
POSTGRES_USER=uphunter
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_ENABLED=true

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMP_SCORING=0.3
OPENAI_TEMP_COVER_LETTER=0.7
OPENAI_TEMP_TRANSLATION=0.3

# ── Upwork OAuth 2.0 ─────────────────────────────────────────────────────────
UPWORK_CLIENT_ID=CHANGE_ME
UPWORK_CLIENT_SECRET=CHANGE_ME
UPWORK_REDIRECT_URI=http://localhost:8000/auth/upwork/callback
UPWORK_API_URL=https://www.upwork.com/api/graphql

# ── Auth / Security ──────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Service URLs (internal docker network) ───────────────────────────────────
JOBS_SERVICE_URL=http://jobs:8101
AI_SCORING_SERVICE_URL=http://ai-scoring:8102
CLIENT_INTEL_SERVICE_URL=http://client-intel:8103
LETTER_GEN_SERVICE_URL=http://letter-gen:8104
AUTH_SERVICE_URL=http://auth:8105
ANALYTICS_SERVICE_URL=http://analytics:8106

# ── Polling ──────────────────────────────────────────────────────────────────
JOBS_POLL_INTERVAL_SECONDS=300

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
